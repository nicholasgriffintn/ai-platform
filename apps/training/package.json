{
	"name": "@assistant/training",
	"version": "0.0.1",
	"private": true,
	"description": "Training Worker service for training and deployment jobs",
	"type": "module",
	"main": "src/index.ts",
	"scripts": {
		"build": "tsc",
		"dev": "pnpm --filter @assistant/schemas build && wrangler dev",
		"start": "pnpm --filter @assistant/schemas build && wrangler dev",
		"typecheck": "pnpm --filter @assistant/schemas build && tsc --noEmit",
		"lint": "pnpm oxlint",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"check": "pnpm lint && pnpm format:check",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"ci:test": "pnpm run coverage",
		"deploy": "pnpm --filter @assistant/schemas build && pnpm typecheck && wrangler deploy"
	},
	"dependencies": {
		"@assistant/schemas": "workspace:*",
		"@aws-sdk/client-bedrock": "3.1068.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260616.1",
		"@types/node": "25.9.3",
		"oxfmt": "0.54.0",
		"oxlint": "1.69.0",
		"typescript": "6.0.3",
		"vitest": "4.1.9",
		"wrangler": "4.100.0"
	}
}
