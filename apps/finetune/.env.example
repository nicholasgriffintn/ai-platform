# Shared AWS credentials
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# Bedrock jobs
BEDROCK_OUTPUT_BUCKET=your-output-bucket-name
BEDROCK_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/BedrockFineTuningRole
# BEDROCK_KMS_KEY_ARN=arn:aws:kms:us-east-1:ACCOUNT_ID:key/KEY_ID
# BEDROCK_VPC_SECURITY_GROUP_IDS=sg-xxxxx,sg-yyyyy
# BEDROCK_VPC_SUBNET_IDS=subnet-xxxxx,subnet-yyyyy

# SageMaker jobs. Falls back to shared AWS credentials when overrides are unset.
SAGEMAKER_REGION=us-east-1
SAGEMAKER_AWS_ACCESS_KEY_ID=
SAGEMAKER_AWS_SECRET_ACCESS_KEY=
SAGEMAKER_AWS_SESSION_TOKEN=
SAGEMAKER_ROLE_ARN=arn:aws:iam::ACCOUNT_ID:role/SageMakerTrainingRole
SAGEMAKER_OUTPUT_BUCKET=your-sagemaker-output-bucket
SAGEMAKER_VOLUME_SIZE_GB=30
