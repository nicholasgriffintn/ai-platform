{
	"name": "@assistant/metrics",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter @assistant/schemas build && vite",
		"build": "pnpm --filter @assistant/schemas build && tsc -b && vite build",
		"preview": "vite preview",
		"watch": "vite build --watch",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "pnpm oxlint",
		"check": "pnpm lint && pnpm format:check",
		"wrangler:dev": "pnpm run build && wrangler dev --remote",
		"deploy": "pnpm run build && wrangler deploy --minify",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"ci:test": "pnpm run coverage"
	},
	"dependencies": {
		"@radix-ui/react-label": "2.1.10",
		"@radix-ui/react-scroll-area": "1.2.12",
		"@radix-ui/react-select": "2.3.1",
		"@radix-ui/react-slot": "1.3.0",
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-query-devtools": "5.101.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"lucide-react": "1.21.0",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"recharts": "3.8.1",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260624.1",
		"@tailwindcss/typography": "0.5.20",
		"@tailwindcss/vite": "4.3.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"globals": "17.7.0",
		"jsdom": "29.1.1",
		"oxfmt": "0.56.0",
		"oxlint": "1.71.0",
		"rollup-plugin-visualizer": "7.0.1",
		"terser": "5.48.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vitest": "4.1.9",
		"wrangler": "4.103.0"
	}
}
