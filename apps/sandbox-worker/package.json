{
	"name": "@assistant/sandbox-worker",
	"version": "0.0.1",
	"private": true,
	"license": "Apache-2.0",
	"main": "src/index.ts",
	"scripts": {
		"dev": "pnpm --filter @assistant/schemas build && wrangler dev src/index.ts",
		"start": "pnpm --filter @assistant/schemas build && wrangler dev src/index.ts",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"ci:test": "pnpm run coverage",
		"cf-typegen": "wrangler types",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "pnpm oxlint",
		"check": "pnpm lint && pnpm format:check",
		"typecheck": "pnpm --filter @assistant/schemas build && tsc --noEmit",
		"deploy": "pnpm --filter @assistant/schemas build && pnpm typecheck && wrangler deploy"
	},
	"dependencies": {
		"@assistant/agent-core": "workspace:*",
		"@assistant/schemas": "workspace:*",
		"@cloudflare/sandbox": "0.11.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260606.1",
		"@types/node": "25.9.2",
		"oxfmt": "0.53.0",
		"oxlint": "1.68.0",
		"typescript": "6.0.3",
		"wrangler": "4.97.0"
	}
}
