{
	"name": "@assistant/app",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter @assistant/schemas build && react-router dev",
		"dev:scan": "pnpm dev & npx react-scan@latest localhost:5173",
		"build": "pnpm run typecheck && react-router build",
		"start": "wrangler dev",
		"watch": "react-router build --watch",
		"typecheck": "pnpm --filter @assistant/schemas build && react-router typegen && tsc -b",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "pnpm oxlint",
		"check": "pnpm lint && pnpm format:check",
		"wrangler:dev": "pnpm run build && wrangler dev --remote",
		"deploy": "pnpm run build && wrangler deploy --minify",
		"sync": "npx cap sync",
		"test": "vitest run",
		"coverage": "vitest run --coverage",
		"ci:test": "pnpm run coverage"
	},
	"dependencies": {
		"@assistant/schemas": "workspace:*",
		"@babel/standalone": "8.0.2",
		"@mlc-ai/web-llm": "0.2.84",
		"@radix-ui/react-checkbox": "1.3.5",
		"@radix-ui/react-dialog": "1.1.17",
		"@radix-ui/react-dropdown-menu": "2.1.18",
		"@radix-ui/react-label": "2.1.10",
		"@radix-ui/react-popover": "1.1.17",
		"@radix-ui/react-select": "2.3.1",
		"@radix-ui/react-slider": "1.4.1",
		"@radix-ui/react-slot": "1.3.0",
		"@radix-ui/react-switch": "1.3.1",
		"@radix-ui/react-tabs": "1.1.15",
		"@radix-ui/react-toggle": "1.1.12",
		"@radix-ui/react-toggle-group": "1.1.13",
		"@react-router/node": "7.18.0",
		"@react-router/serve": "7.18.0",
		"@simplewebauthn/browser": "13.3.0",
		"@strudel/codemirror": "1.3.0",
		"@strudel/core": "1.2.5",
		"@strudel/draw": "1.2.5",
		"@strudel/hydra": "1.2.5",
		"@strudel/midi": "1.3.0",
		"@strudel/mini": "1.2.5",
		"@strudel/soundfonts": "1.3.0",
		"@strudel/tonal": "1.2.5",
		"@strudel/transpiler": "1.2.5",
		"@strudel/webaudio": "1.3.0",
		"@tanstack/react-query": "5.101.0",
		"@tanstack/react-query-devtools": "5.101.0",
		"class-variance-authority": "0.7.1",
		"clsx": "2.1.1",
		"idb": "8.0.3",
		"isbot": "5.1.43",
		"lucide-react": "1.21.0",
		"next-themes": "0.4.6",
		"posthog-js": "1.391.2",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-markdown": "10.1.0",
		"react-router": "7.18.0",
		"rehype-highlight": "7.0.2",
		"remark-gfm": "4.0.1",
		"sonner": "2.0.7",
		"tailwind-merge": "3.6.0",
		"tailwindcss": "4.3.1",
		"tw-animate-css": "1.4.0",
		"virtua": "0.49.1",
		"zustand": "5.0.14"
	},
	"devDependencies": {
		"@babel/preset-typescript": "8.0.1",
		"@cloudflare/workers-types": "4.20260617.1",
		"@react-router/dev": "7.18.0",
		"@simplewebauthn/types": "12.0.0",
		"@tailwindcss/typography": "0.5.20",
		"@tailwindcss/vite": "4.3.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@types/babel__standalone": "7.1.9",
		"@types/node": "25.9.4",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.2",
		"babel-plugin-react-compiler": "1.0.0",
		"globals": "17.6.0",
		"jsdom": "29.1.1",
		"oxfmt": "0.55.0",
		"oxlint": "1.71.0",
		"rollup-plugin-visualizer": "7.0.1",
		"terser": "5.48.0",
		"typescript": "6.0.3",
		"vite": "8.0.16",
		"vite-plugin-babel": "1.7.3",
		"vitest": "4.1.9",
		"wrangler": "4.103.0"
	}
}
