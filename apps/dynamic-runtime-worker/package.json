{
	"name": "@assistant/dynamic-runtime-worker",
	"license": "Apache-2.0",
	"version": "0.0.1",
	"private": true,
	"main": "src/index.ts",
	"scripts": {
		"dev": "pnpm --filter @assistant/schemas build && wrangler dev src/index.ts",
		"start": "pnpm --filter @assistant/schemas build && wrangler dev src/index.ts",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"cf-typegen": "wrangler types",
		"format": "pnpm prettier --write .",
		"format:check": "pnpm prettier --check .",
		"lint": "pnpm oxlint",
		"check": "pnpm lint && pnpm format:check",
		"typecheck": "pnpm --filter @assistant/schemas build && tsc --noEmit",
		"deploy": "pnpm --filter @assistant/schemas build && pnpm typecheck && wrangler deploy src/index.ts --name=assistant-dynamic-runtime-worker"
	},
	"dependencies": {
		"@assistant/schemas": "workspace:*",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260317.1",
		"@prettier/plugin-oxc": "0.1.3",
		"@types/node": "25.5.0",
		"oxlint": "1.56.0",
		"prettier": "3.8.1",
		"typescript": "5.9.3",
		"vitest": "4.1.1",
		"wrangler": "4.75.0"
	}
}
