{
	"name": "@assistant/api",
	"version": "0.0.1",
	"private": true,
	"license": "Apache-2.0",
	"main": "src/index.ts",
	"scripts": {
		"build": "pnpm --filter @assistant/schemas build",
		"deploy": "pnpm build && pnpm typecheck && wrangler deploy src/index.ts --name=assistant",
		"dev": "pnpm --filter @assistant/schemas build && wrangler dev src/index.ts",
		"start": "wrangler dev src/index.ts",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"ci:test": "pnpm run coverage",
		"cf-typegen": "wrangler types",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "pnpm oxlint",
		"check": "pnpm lint && pnpm format:check",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:up": "drizzle-kit up:sqlite",
		"db:migrate:local": "wrangler d1 migrations apply personal-assistant --local",
		"db:migrate:preview": "wrangler d1 migrations apply personal-assistant-preview --remote",
		"db:migrate:prod": "wrangler d1 migrations apply personal-assistant --remote",
		"db:sync:preview": "bash ./scripts/db-sync-preview.sh",
		"models:sync": "node ./scripts/sync-models-dev.mjs",
		"db:studio:local": "DB_LOCAL_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
		"db:studio:preview": "NODE_ENV='preview' drizzle-kit studio",
		"db:studio:prod": "drizzle-kit studio"
	},
	"dependencies": {
		"@assistant/agent-core": "workspace:*",
		"@assistant/schemas": "workspace:*",
		"@hono/standard-validator": "0.2.3",
		"@hono/zod-validator": "0.8.0",
		"@octokit/rest": "22.0.1",
		"@scalar/hono-api-reference": "0.11.8",
		"@sentry/cloudflare": "10.63.0",
		"@simplewebauthn/server": "13.3.2",
		"@tsndr/cloudflare-worker-jwt": "3.2.1",
		"agents": "0.13.3",
		"aws4fetch": "1.0.20",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.27",
		"hono-openapi": "1.3.1",
		"isbot": "5.1.44",
		"posthog-node": "^5.38.2",
		"stripe": "22.3.0",
		"zod": "4.4.3",
		"zod-openapi": "6.0.0"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "5.20260715.1",
		"@simplewebauthn/types": "12.0.0",
		"@types/node": "25.9.4",
		"better-sqlite3": "12.11.1",
		"drizzle-kit": "0.31.10",
		"oxfmt": "0.57.0",
		"oxlint": "1.72.0",
		"typescript": "6.0.3",
		"vitest": "4.1.9",
		"wrangler": "4.107.1"
	}
}
