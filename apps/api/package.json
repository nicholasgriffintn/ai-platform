{
	"name": "@assistant/api",
	"license": "Apache-2.0",
	"version": "0.0.1",
	"private": true,
	"main": "src/index.ts",
	"scripts": {
		"build": "pnpm --filter @assistant/schemas build",
		"deploy": "pnpm typecheck && wrangler deploy src/index.ts --name=assistant",
		"dev": "pnpm --filter @assistant/schemas build && wrangler dev src/index.ts",
		"start": "wrangler dev src/index.ts",
		"test": "vitest",
		"coverage": "vitest run --coverage",
		"cf-typegen": "wrangler types",
		"format": "pnpm prettier --write .",
		"format:check": "pnpm prettier --check .",
		"lint": "pnpm oxlint",
		"check": "pnpm lint && pnpm format:check",
		"typecheck": "tsc --noEmit",
		"db:generate": "drizzle-kit generate",
		"db:up": "drizzle-kit up:sqlite",
		"db:migrate:local": "wrangler d1 migrations apply personal-assistant --local",
		"db:migrate:preview": "wrangler d1 migrations apply personal-assistant-preview --remote",
		"db:migrate:prod": "wrangler d1 migrations apply personal-assistant --remote",
		"db:sync:preview": "bash ./scripts/db-sync-preview.sh",
		"models:sync": "node ./scripts/sync-models-dev.mjs",
		"db:studio:local": "DB_LOCAL_PATH=$(find .wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name '*.sqlite' -print -quit) drizzle-kit studio",
		"db:studio:preview": "NODE_ENV='preview' drizzle-kit studio",
		"db:studio:prod": "drizzle-kit studio"
	},
	"dependencies": {
		"@assistant/agent-core": "workspace:*",
		"@assistant/schemas": "workspace:*",
		"@hono/standard-validator": "0.2.2",
		"@hono/zod-validator": "0.7.6",
		"@octokit/rest": "22.0.1",
		"@scalar/hono-api-reference": "0.10.10",
		"@simplewebauthn/server": "13.3.0",
		"@tsndr/cloudflare-worker-jwt": "3.2.1",
		"agents": "0.11.5",
		"aws4fetch": "1.0.20",
		"drizzle-orm": "0.45.2",
		"hono": "4.12.15",
		"hono-openapi": "1.3.0",
		"isbot": "5.1.39",
		"stripe": "20.4.1",
		"zod": "4.3.6",
		"zod-openapi": "5.4.6"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "4.20260410.1",
		"@prettier/plugin-oxc": "0.1.4",
		"@simplewebauthn/types": "12.0.0",
		"@types/node": "25.6.0",
		"better-sqlite3": "12.9.0",
		"drizzle-kit": "0.31.10",
		"oxlint": "1.61.0",
		"prettier": "3.8.3",
		"typescript": "6.0.3",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.1.5",
		"wrangler": "4.85.0"
	}
}
