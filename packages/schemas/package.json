{
	"name": "@assistant/schemas",
	"version": "0.0.1",
	"private": false,
	"license": "Apache-2.0",
	"files": [
		"dist",
		"src"
	],
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"typecheck": "tsc --noEmit",
		"format": "oxfmt",
		"format:check": "oxfmt --check",
		"lint": "pnpm oxlint",
		"check": "pnpm lint && pnpm format:check"
	},
	"dependencies": {
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@types/node": "25.9.1",
		"oxfmt": "0.51.0",
		"oxlint": "1.66.0",
		"tsup": "8.5.1",
		"typescript": "6.0.3"
	},
	"peerDependencies": {
		"zod": "4.3.6"
	}
}
